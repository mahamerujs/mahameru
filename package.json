{
  "name": "mahameru",
  "version": "0.0.37",
  "description": "Mahameru is a minimal and fast Node.js framework for building HTTP servers",
  "bin": {
    "mahameru": "./dist/cli/index.js"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "build": "tsup --config tsup.config.ts && node ./scripts/postbuild.js",
    "dev": "cross-env NODE_ENV=development tsup --config tsup.config.ts && node ./scripts/postbuild.js",
    "postinstall": "node ./scripts/postinstall.js"
  },
  "keywords": [
    "mahamerujs",
    "mahameru",
    "nodejs",
    "typescript",
    "http",
    "http-server",
    "framework",
    "node-framework",
    "backend",
    "routing",
    "file-based-routing",
    "dependency-injection",
    "server"
  ],
  "author": "Bintan <hello@bintvn.co>",
  "license": "ISC",
  "engines": {
    "node": ">=20.6.0"
  },
  "dependencies": {
    "@mahameru/diatrema": "^0.0.2",
    "commander": "^15.0.0",
    "ora": "^9.4.1",
    "picocolors": "^1.1.1",
    "prompts": "^2.4.2",
    "ts-morph": "^28.0.0",
    "tsc-alias": "^1.9.1",
    "tsx": "^4.23.1"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@types/prompts": "^2.4.9",
    "cross-env": "^10.1.0",
    "esbuild-fix-imports-plugin": "^1.0.23",
    "tsup": "^8.5.1",
    "type-fest": "^5.7.0",
    "typescript": "^6.0.3"
  },
  "allowScripts": {
    "@mahameru/diatrema": true
  }
}
