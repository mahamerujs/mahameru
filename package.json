{
  "name": "mahameru",
  "version": "0.0.8",
  "description": "Mahameru is a minimal and fast Node.js framework for building HTTP servers",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js",
      "default": "./dist/core/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "clean": "rimraf dist .types",
    "build": "npm run clean && webpack && tsc --project tsconfig.types-root.json && node -e \"require('fs').copyFileSync('.types/index.d.ts', 'dist/index.d.ts')\" && dts-bundle-generator --config dts-bundle.config.json && rimraf .types",
    "prepare": "npm run build"
  },
  "keywords": [
    "mahamerujs",
    "mahameru",
    "nodejs",
    "typescript",
    "http",
    "http-server",
    "framework",
    "node-framework",
    "backend",
    "routing",
    "file-based-routing",
    "dependency-injection",
    "server"
  ],
  "author": "Bintan <hello@bintvn.co>",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/webpack-node-externals": "^3.0.4",
    "boxen": "^8.0.1",
    "copy-webpack-plugin": "^14.0.0",
    "dts-bundle-generator": "^9.5.1",
    "rimraf": "^6.1.3",
    "strip-ansi": "^7.2.0",
    "ts-loader": "^9.6.1",
    "tsc-alias": "^1.8.17",
    "tsconfig-paths-webpack-plugin": "^4.2.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "webpack": "^5.107.2",
    "webpack-cli": "^7.0.3",
    "webpack-node-externals": "^3.0.0"
  }
}
