{
  "name": "mahameru",
  "version": "0.0.17",
  "description": "Mahameru is a minimal and fast Node.js framework for building HTTP servers",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch --no-splitting",
    "build": "tsup src --format cjs,esm --dts --clean --no-splitting",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "clean": "rimraf dist",
    "build:tsc": "tsc --project tsconfig.json",
    "prepare": "npm run build"
  },
  "keywords": [
    "mahamerujs",
    "mahameru",
    "nodejs",
    "typescript",
    "http",
    "http-server",
    "framework",
    "node-framework",
    "backend",
    "routing",
    "file-based-routing",
    "dependency-injection",
    "server"
  ],
  "author": "Bintan <hello@bintvn.co>",
  "license": "ISC",
  "engines": {
    "node": ">=20.6.0"
  },
  "devDependencies": {
    "@swc/core": "^1.15.43",
    "@types/node": "^26.0.1",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  }
}
