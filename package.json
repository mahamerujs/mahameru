{
  "name": "mahamerujs",
  "private": true,
  "scripts": {
    "dev": "turbo watch dev:js dev:types",
    "dev:diatrema": "turbo watch dev:js dev:types --filter=@mahameru/diatrema...",
    "dev:magma": "turbo watch dev:js dev:types --filter=@mahameru/magma... --filter=mahameru",
    "dev:mahameru": "turbo watch dev:js dev:types --filter=mahameru...",
    "build": "turbo run build:js build:types",
    "build:diatrema": "turbo run build:js build:types --filter=@mahameru/diatrema...",
    "build:magma": "turbo run build:js build:types --filter=@mahameru/magma...",
    "build:mahameru": "turbo run build:js build:types --filter=mahameru...",
    "clean": "turbo clean && rimraf --glob .turbo \"packages/*/dist\" \"packages/*/.turbo\" node_modules/.cache",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint -- --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,json,md}\"",
    "typecheck": "turbo run typecheck",
    "change": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.1",
    "@eslint/js": "^10.0.1",
    "esbuild-fix-imports-plugin": "^1.0.23",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "prettier": "^3.9.6",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "turbo": "^2.10.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.65.0"
  },
  "packageManager": "pnpm@11.15.1"
}
