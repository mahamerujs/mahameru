{
  "name": "mahameru",
  "version": "0.0.15",
  "description": "Mahameru is a minimal and fast Node.js framework for building HTTP servers",
  "main": "./dist/mahameru.js",
  "types": "./dist/mahameru.d.ts",
  "type": "commonjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "clean": "rimraf dist",
    "build": "tsc --project tsconfig.json",
    "prepare": "npm run build"
  },
  "keywords": [
    "mahamerujs",
    "mahameru",
    "nodejs",
    "typescript",
    "http",
    "http-server",
    "framework",
    "node-framework",
    "backend",
    "routing",
    "file-based-routing",
    "dependency-injection",
    "server"
  ],
  "author": "Bintan <hello@bintvn.co>",
  "license": "ISC",
  "engines": {
    "node": ">=20.6.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@types/webpack-node-externals": "^3.0.4",
    "boxen": "^8.0.1",
    "porterman": "^0.0.2",
    "rimraf": "^6.1.3",
    "strip-ansi": "^7.2.0",
    "terser-webpack-plugin": "^5.6.1",
    "ts-loader": "^9.6.2",
    "tsc-alias": "^1.8.17",
    "tsconfig-paths-webpack-plugin": "^4.2.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "webpack": "^5.107.2",
    "webpack-cli": "^7.0.3",
    "webpack-node-externals": "^3.0.0"
  },
  "dependencies": {
    "commander": "^15.0.0",
    "ora": "^9.4.1",
    "picocolors": "^1.1.1"
  },
  "peerDependencies": {
    "porterman": "^0.0.2"
  }
}
