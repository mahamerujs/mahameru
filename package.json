{
  "name": "mahameru",
  "version": "0.0.24",
  "description": "Mahameru is a minimal and fast Node.js framework for building HTTP servers",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs",
      "default": "./dist/index.js"
    },
    "./typeorm": {
      "types": "./dist/typeorm/index.d.ts",
      "require": "./dist/typeorm/index.js",
      "import": "./dist/typeorm/index.mjs",
      "default": "./dist/typeorm/index.js"
    }
  },
  "scripts": {
    "dev": "tsup --config tsup.dev.config.ts",
    "build": "tsup --config tsup.build.config.ts",
    "typecheck": "tsc --noEmit --project tsconfig.json"
  },
  "keywords": [
    "mahamerujs",
    "mahameru",
    "nodejs",
    "typescript",
    "http",
    "http-server",
    "framework",
    "node-framework",
    "backend",
    "routing",
    "file-based-routing",
    "dependency-injection",
    "server"
  ],
  "author": "Bintan <hello@bintvn.co>",
  "license": "ISC",
  "engines": {
    "node": ">=20.6.0"
  },
  "devDependencies": {
    "@swc/core": "^1.15.43",
    "@types/node": "^26.0.1",
    "tsup": "^8.5.1",
    "type-fest": "^5.7.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "reflect-metadata": "^0.2.2",
    "typeorm": "^1.0.0"
  }
}
