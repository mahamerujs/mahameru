{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "typecheck": {
      "cache": false,
      "persistent": false,
      "outputs": []
    },
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**"
      ]
    },
    "build:js": {
      "outputs": [
        "dist/**/*.js",
        "dist/**/*.cjs",
        "dist/**/*.map"
      ]
    },
    "build:types": {
      "outputs": [
        "dist/**/*.d.ts",
        "dist/**/*.d.ts.map"
      ]
    },
    "lint": {
      "outputs": []
    },
    "dev:js": {
      "cache": false,
      "persistent": true
    },
    "dev:types": {
      "cache": false,
      "persistent": true
    }
  }
}