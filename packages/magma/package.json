{
  "name": "@mahameru/magma",
  "version": "0.0.5",
  "description": "Official HTTP server plugin for Mahameru JS framework, providing fast and minimalist routing capabilities.",
  "mahameru": {
    "name": "magma",
    "type": "plugin"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "build:js": "tsup",
    "build:types": "tsc",
    "build": "pnpm build:js && pnpm build:types",
    "dev:js": "tsup --watch",
    "dev:types": "tsc --watch --preserveWatchOutput",
    "dev": "pnpm dev:js && pnpm dev:types"
  },
  "keywords": [
    "node",
    "framework",
    "mahameru",
    "mahamerujs",
    "http-server",
    "https-server",
    "web-server"
  ],
  "author": "Bintan <hello@bintvn.co>",
  "license": "ISC",
  "publishConfig": {
    "access": "public",
    "directory": "dist"
  },
  "engines": {
    "node": ">=20.6.0"
  },
  "peerDependencies": {
    "@mahameru/diatrema": "workspace:*"
  },
  "devDependencies": {
    "@mahameru/diatrema": "workspace:*",
    "@types/node": "^26.1.0",
    "type-fest": "^5.8.0"
  }
}