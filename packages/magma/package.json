{
  "name": "@mahameru/magma",
  "version": "0.0.5",
  "description": "Official HTTP server plugin for Mahameru JS framework, providing fast and minimalist routing capabilities.",
  "mahameru": {
    "name": "magma",
    "type": "plugin"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "keywords": [
    "node",
    "framework",
    "mahameru",
    "mahamerujs",
    "http-server",
    "https-server",
    "web-server"
  ],
  "author": "Bintan <hello@bintvn.co>",
  "license": "ISC",
  "engines": {
    "node": ">=20.6.0"
  },
  "publishConfig": {
    "directory": "dist"
  },
  "peerDependencies": {
    "@mahameru/diatrema": "workspace:*"
  },
  "devDependencies": {
    "@mahameru/diatrema": "workspace:*",
    "@types/node": "^26.1.0",
    "esbuild-fix-imports-plugin": "^1.0.23",
    "tsup": "^8.5.1",
    "type-fest": "^5.8.0",
    "typescript": "^6.0.3"
  }
}