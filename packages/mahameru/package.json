{
  "name": "mahameru",
  "version": "0.0.41",
  "description": "Mahameru is a minimal and fast Node.js framework for building HTTP servers",
  "bin": {
    "mahameru": "./dist/cli/index.js"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "build:js": "tsup",
    "build:types": "tsc",
    "build": "rimraf dist && tsup && tsc",
    "dev:js": "tsup --watch",
    "dev:types": "tsc --watch --preserveWatchOutput",
    "dev": "pnpm dev:js && pnpm dev:types"
  },
  "keywords": [
    "mahamerujs",
    "mahameru",
    "nodejs",
    "typescript",
    "http",
    "http-server",
    "framework",
    "node-framework",
    "backend",
    "routing",
    "file-based-routing",
    "dependency-injection",
    "server"
  ],
  "author": "Bintan <hello@bintvn.co>",
  "license": "ISC",
  "publishConfig": {
    "access": "public",
    "directory": "dist"
  },
  "engines": {
    "node": ">=20.6.0"
  },
  "peerDependencies": {
    "@mahameru/diatrema": "workspace:*"
  },
  "dependencies": {
    "commander": "^15.0.0",
    "ora": "^9.4.1",
    "picocolors": "^1.1.1",
    "prompts": "^2.4.2",
    "ts-morph": "^28.0.0",
    "tsc-alias": "^1.9.1"
  },
  "devDependencies": {
    "@mahameru/diatrema": "workspace:*",
    "@types/node": "^26.0.1",
    "@types/prompts": "^2.4.9",
    "type-fest": "^5.7.0"
  }
}
