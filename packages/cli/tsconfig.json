{
	"compilerOptions": {
		"target": "ESNext",
		"module": "nodenext",
		"moduleResolution": "nodenext",
		"rootDir": "./src",
		"outDir": "./dist",
		"declaration": false,
		"resolveJsonModule": true,
		"emitDecoratorMetadata": true,
		"experimentalDecorators": true,
		"types": [
			"node"
		],
		"paths": {
			"@/*": [
				"./src/*"
			]
		}
	},
	"include": [
		"./src/**/*.ts"
	],
	"exclude": [
		"./node_modules",
		"./dist"
	],
	"ts-node": {
		"compilerOptions": {
			"module": "CommonJS"
		}
	}
}