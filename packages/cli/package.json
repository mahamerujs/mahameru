{
  "name": "@mahameru/cli",
  "version": "0.0.38",
  "description": "MahameruJS CLI Utility - The command-line interface for running and building Mahameru-based applications",
  "bin": {
    "mahameru": "./cli.js"
  },
  "scripts": {
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "clean": "rimraf dist",
    "build": "npm run clean && webpack",
    "build:install": "npm run build && npm i -g .\\dist\\dist.tgz"
  },
  "keywords": [
    "mahameruJS",
    "mahameru",
    "cli",
    "framework",
    "nodejs",
    "typescript",
    "web-server",
    "build-tool",
    "developer-tools",
    "process-manager"
  ],
  "author": "Bintan <hello@bintvn.co>",
  "license": "ISC",
  "files": [
    "cli.js",
    "mpm"
  ],
  "engines": {
    "node": ">=20.6.0"
  },
  "dependencies": {
    "adm-zip": "^0.5.18",
    "commander": "^15.0.0",
    "console-table-without-index": "^0.1.1",
    "ora": "^9.4.1",
    "picocolors": "^1.1.1",
    "porterman": "^0.0.3",
    "socket.io": "^4.8.3",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.22.4"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^26.0.0",
    "@types/socket.io": "^3.0.1",
    "@types/webpack-node-externals": "^3.0.4",
    "boxen": "^8.0.1",
    "rimraf": "^6.1.3",
    "strip-ansi": "^7.2.0",
    "terser-webpack-plugin": "^5.6.1",
    "ts-loader": "^9.6.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths-webpack-plugin": "^4.2.0",
    "type-fest": "^5.7.0",
    "typescript": "^6.0.3",
    "webpack": "^5.107.2",
    "webpack-cli": "^7.0.3",
    "webpack-node-externals": "^3.0.0"
  }
}